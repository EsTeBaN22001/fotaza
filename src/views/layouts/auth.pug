doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Fotaza - Auth

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css",
      rel="stylesheet"
    )

  body.bg-light

    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") Fotaza

        button.navbar-toggler(
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarAuth"
        )
          span.navbar-toggler-icon

        .collapse.navbar-collapse#navbarAuth
          ul.navbar-nav.ms-auto
            li.nav-item
              a.nav-link(href="/auth/login") Iniciar sesión
            li.nav-item
              a.nav-link(href="/auth/register") Registro

    .container.mt-3
      if success
        .row.justify-content-center
          .col-md-6.col-lg-4
            .alert.alert-success.text-center= success

      if errors && errors.length
        .row.justify-content-center
          .col-md-6.col-lg-4
            .card.border-danger.shadow-sm
              .card-body
                h6.text-danger.mb-2 Errores:
                ul.mb-0
                  each err in errors
                    li= err.message

    block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")