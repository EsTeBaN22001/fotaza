extends ../layouts/app

block content
  if !posts || posts.length === 0
    .container.mt-5.text-center
      .display-4.mb-3 📷
      h2.fw-bold.mb-3 Aún no hay publicaciones
      p.lead.text-muted.mb-4
        | Sé el primero en compartir tu trabajo con la comunidad.
      
      .d-flex.justify-content-center.gap-3
        if user
          a.btn.btn-primary.btn-lg(href='/posts/create')
            i.bi.bi-camera-fill.me-2
            | Crear mi primera publicación
        else
          a.btn.btn-outline-primary.btn-lg(href='/auth/register')
            i.bi.bi-person-plus-fill.me-2
            | Registrarme para publicar
          a.btn.btn-link.btn-lg(href='/auth/login')
            | Ya tengo cuenta

      .row.mt-5.justify-content-center
        .col-md-8
          .alert.alert-info.text-start
            h6.fw-bold.mb-2 ¿Qué puedo publicar en Fotaza?
            ul.mb-0.ps-3
              li 🏞️ Paisajes y naturaleza
              li 🏙️ Fotografía urbana y arquitectura
              li 👤 Retratos y moda
              li 🎨 Arte digital y edición creativa
            small.d-block.mt-2.text-muted
              | Recuerda: todas las imágenes deben ser de tu autoría.

  else
    .row.row-cols-1.row-cols-md-3.g-4
      each post in posts
        - const ratings = post.Ratings || []
        - const ratingCount = ratings.length
        - const ratingAvg = ratingCount > 0 ? (ratings.reduce((sum, r) => sum + r.value, 0) / ratingCount).toFixed(1) : null
        .col
          .card.shadow-sm.h-100.border-0.rounded-4.overflow-hidden

            if post.images.length == 1
              .position-relative
                a(href=`/posts/${post.id}`)
                  img.card-img-top(
                    src=`/images/${post.images[0].id}`
                    alt=post.title
                    style="height: 220px; object-fit: cover;"
                    loading="lazy"
                  )
                //- Badge de licencia
                if post.images[0].license === 'copyright'
                  span.badge.bg-dark.position-absolute.bottom-0.start-0.m-2(style="opacity:0.8;")
                    i.bi.bi-c-circle.me-1
                    | Copyright

            else if post.images.length > 1
              - const carouselId = 'carousel-' + post.id
              .position-relative
                .carousel.slide(id=carouselId data-bs-ride="carousel")
                  .carousel-inner
                    each img, index in post.images
                      .carousel-item(class=index === 0 ? 'active' : '')
                        a(href=`/posts/${post.id}`)
                          img.d-block.w-100(
                            src=`/images/${img.id}`
                            alt=post.title
                            style="height: 220px; object-fit: cover;"
                            loading="lazy"
                          )

                  button.carousel-control-prev(
                    type="button"
                    data-bs-target='#' + carouselId
                    data-bs-slide="prev"
                  )
                    span.carousel-control-prev-icon

                  button.carousel-control-next(
                    type="button"
                    data-bs-target='#' + carouselId
                    data-bs-slide="next"
                  )
                    span.carousel-control-next-icon

            else
              a(href=`/posts/${post.id}`)
                img.card-img-top(
                  src="/placeholder.svg"
                  alt="Sin imagen"
                  style="height: 220px; object-fit: cover;"
                )

            .card-body.d-flex.flex-column.px-3.py-2
              h5.card-title.mb-1
                a.text-decoration-none.text-dark.fw-semibold(href=`/posts/${post.id}`)= post.title
              
              p.card-text.text-muted.small.mb-2= post.description && post.description.length > 90 ? post.description.substring(0, 90) + '…' : post.description

              //- Rating display
              .d-flex.align-items-center.gap-2.mb-2
                if ratingAvg
                  .d-flex.align-items-center.gap-1
                    - for (let s = 1; s <= 5; s++)
                      i.bi.small(class=s <= Math.round(parseFloat(ratingAvg)) ? 'bi-star-fill text-warning' : 'bi-star text-muted')
                    span.small.fw-bold.text-warning= ratingAvg
                    span.text-muted.small (#{ratingCount})
                else
                  span.text-muted.small
                    i.bi.bi-star.me-1
                    | Sin valoraciones

              .d-flex.align-items-center.gap-3.mb-2
                - const isLiked = user && post.Likes && post.Likes.some(l => l.UserId === user.id)
                - const likeCount = post.Likes ? post.Likes.length : 0
                if user
                  button.btn.btn-link.p-0.text-decoration-none.like-btn.small(
                    class=isLiked ? 'text-danger' : 'text-muted'
                    data-post-id=post.id
                    aria-label=isLiked ? 'Quitar me gusta' : 'Dar me gusta'
                  )
                    i.bi(class=isLiked ? 'bi-heart-fill' : 'bi-heart').me-1
                    span.like-count= likeCount
                    |  me gusta
                else
                  span.text-muted.small(title="Inicia sesión para dar me gusta")
                    i.bi.bi-heart.me-1
                    span.like-count= likeCount
                    |  me gusta
                    i.bi.bi-lock-fill.ms-1.text-secondary(style="font-size: 0.75rem;")

                - const isSaved = user && post.Bookmarks && post.Bookmarks.some(b => b.UserId === user.id)
                if user
                  button.btn.btn-link.p-0.text-decoration-none.save-btn.small(
                    class=isSaved ? 'text-primary' : 'text-muted'
                    data-post-id=post.id
                    aria-label=isSaved ? 'Quitar de guardados' : 'Guardar'
                  )
                    i.bi(class=isSaved ? 'bi-bookmark-fill' : 'bi-bookmark')
                else
                  span.text-muted.small(title="Inicia sesión para guardar")
                    i.bi.bi-bookmark
                    i.bi.bi-lock-fill.ms-1.text-secondary(style="font-size: 0.75rem;")

              if post.Tags && post.Tags.length > 0
                .d-flex.flex-wrap.gap-1.mb-2
                  each tag in post.Tags
                    a.badge.rounded-pill.bg-light.text-primary.border.small.text-decoration-none(href=`/search?tags=${tag.name}`)= tag.name
              
              .flex-grow-1
              
              small.text-muted.d-block.mt-1
                | Por 
                if post.User && post.User.username
                  if user
                    a.text-decoration-none.fw-bold(href=`/profile/${post.User.username}`)= post.User.username
                  else
                    span.fw-bold(title="Inicia sesión para ver perfiles")= post.User.username
                      i.bi.bi-lock-fill.ms-1.text-secondary(style="font-size: 0.7rem;")
                else
                  | Anónimo
                |  • 
                span= new Date(post.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })

  script(src="/js/likes.js")
  script(src="/js/bookmarks.js")