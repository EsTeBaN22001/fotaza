extends ../../layouts/app

block content
  .row.justify-content-center
    .col-md-8

      .card.shadow
        .card-body

          h4.mb-4
            i.bi.bi-camera-fill.me-2
            | Crear Publicación

          if errors && errors.length > 0
            .alert.alert-danger
              ul.mb-0
                each error in errors
                  li= error.message

          form(method="POST" action="/posts" enctype="multipart/form-data" id="createPostForm")

            .mb-3
              label.form-label.fw-semibold Título
              input.form-control(
                type="text"
                name="title"
                value=old.title
                placeholder="Dale un título llamativo a tu publicación"
                required
              )

            .mb-3
              label.form-label.fw-semibold Descripción
              textarea.form-control(name="description" rows="4" placeholder="Describe tu publicación..." required)= old.description

            .mb-3
              label.form-label.fw-semibold
                i.bi.bi-images.me-1
                | Imágenes (máximo 5)
              input.form-control#imageInput(
                type="file"
                name="images"
                multiple
                accept="image/*"
                required
              )
              small.text-muted Formatos permitidos: JPG, PNG, WebP, GIF. Máximo 10MB por imagen.

            //- Preview dinámico con controles de licencia por imagen
            #imagePreviewContainer.mt-3

            if tags && tags.length > 0
              .mb-3
                label.form-label.fw-semibold Etiquetas (Tags)
                .d-flex.flex-wrap.gap-2
                  each tag in tags
                    .form-check
                      input.form-check-input(
                        type="checkbox"
                        name="tags"
                        value=tag.id
                        id=`tag-${tag.id}`
                        checked=(old.tags && (Array.isArray(old.tags) ? old.tags.includes(tag.id.toString()) : old.tags === tag.id.toString()))
                      )
                      label.form-check-label(for=`tag-${tag.id}`)= tag.name

            .mb-4
              .form-check.form-switch
                input.form-check-input(
                  type="checkbox"
                  name="commentsEnabled"
                  id="commentsEnabled"
                  checked=(old.commentsEnabled !== undefined ? old.commentsEnabled === 'on' : true)
                )
                label.form-check-label(for="commentsEnabled") Habilitar comentarios en esta publicación

            button.btn.btn-primary.w-100(type="submit")
              i.bi.bi-send.me-1
              | Publicar

  style.
    .license-card {
      border: 2px solid #dee2e6;
      border-radius: 8px;
      transition: border-color 0.2s;
    }
    .watermark-field { display: none; }
    .watermark-field.visible { display: block; }
    .img-preview-thumb {
      width: 80px;
      height: 60px;
      object-fit: cover;
      border-radius: 4px;
    }

  script(src="/js/post-create.js")
