extends ../../layouts/app

block content
  .container.mt-4.mb-5

    //- ===== NAVEGACIÓN =====
    .mb-3
      a.text-decoration-none.text-muted(href="/home")
        i.bi.bi-arrow-left.me-1
        | Volver al inicio

    //- ===== LAYOUT BALANCEADO =====
    .row.g-4.align-items-center
      //- 📸 COLUMNA IZQUIERDA: IMÁGENES (CENTRADA VERTICALMENTE)
      .col-lg-8
        .post-media-container.bg-dark.rounded-3.overflow-hidden.shadow-sm(style="min-height: 400px; max-height: 80vh; display: flex; align-items: center; justify-content: center;")
          if post.images && post.images.length > 0
            if post.images.length === 1
              a.w-100.h-100.d-flex.align-items-center(href=`/posts/${post.id}` style="text-decoration: none;")
                img.w-100(
                  src=post.images[0].url
                  alt=post.title
                  style="max-height: 80vh; object-fit: contain;"
                )
            else
              - const carouselId = 'post-carousel-' + post.id
              .carousel.slide.w-100(id=carouselId data-bs-ride="false")
                .carousel-inner
                  each img, idx in post.images
                    .carousel-item(class=idx === 0 ? 'active' : '')
                      a.w-100.h-100.d-flex.align-items-center(href=`/posts/${post.id}` style="text-decoration: none;")
                        img.d-block.w-100(
                          src=img.url
                          alt=`${post.title} - Imagen ${idx + 1}`
                          style="max-height: 80vh; object-fit: contain;"
                        )
                if post.images.length > 1
                  button.carousel-control-prev(type="button" data-bs-target='#' + carouselId data-bs-slide="prev")
                    span.carousel-control-prev-icon
                  button.carousel-control-next(type="button" data-bs-target='#' + carouselId data-bs-slide="next")
                    span.carousel-control-next-icon
          else
            .text-center.text-white.py-5
              i.bi.bi-image.d-block(style="font-size: 3rem;")
              span Sin imágenes

      //- 📝 COLUMNA DERECHA: INFO Y COMENTARIOS (CRECE NATURALMENTE)
      .col-lg-4
        //- TARJETA DE INFORMACIÓN
        .card.shadow-sm.border-0.mb-4
          .card-body.p-4
            h1.h4.fw-bold.mb-3= post.title
            
            .d-flex.align-items-center.mb-4
              .bg-secondary.rounded-circle.d-flex.align-items-center.justify-content-center.me-2(style="width: 40px; height: 40px; min-width: 40px;")
                i.bi.bi-person.text-white
              .flex-grow-1
                if post.User
                  a.fw-bold.text-decoration-none.small(href=`/profile/${post.User.username}`)= post.User.username
                else
                  span.fw-bold.small Anónimo
                .text-muted.x-small
                  span= new Date(post.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'long' })

              if user && post.User && user.id === post.User.id
                .dropdown
                  button.btn.btn-sm.btn-link.text-muted(data-bs-toggle="dropdown")
                    i.bi.bi-three-dots
                  ul.dropdown-menu.dropdown-menu-end
                    li: a.dropdown-item(href=`/profile/edit/${post.id}`) Editar
                    li: hr.dropdown-divider
                    li
                      form(action=`/profile/delete/${post.id}` method="POST")
                        button.dropdown-item.text-danger(type="submit" onclick="return confirm('¿Eliminar?')") Eliminar

            if post.description
              .mb-4
                p.mb-0(style="white-space: pre-wrap; line-height: 1.6; font-size: 0.95rem;")= post.description

            if post.Tags && post.Tags.length > 0
              .mb-4
                .d-flex.flex-wrap.gap-2
                  each tag in post.Tags
                    span.badge.rounded-pill.bg-primary.bg-opacity-10.text-primary.px-3.py-2.small
                      i.bi.bi-tag.me-1
                      = tag.name

            .d-flex.align-items-center.gap-4.text-muted.border-top.pt-3
              span
                button.btn.btn-link.p-0.text-decoration-none.like-btn(
                  class=isLiked ? 'text-danger' : 'text-muted'
                  data-post-id=post.id
                  aria-label=isLiked ? 'Quitar me gusta' : 'Dar me gusta'
                )
                  i.bi(class=isLiked ? 'bi-heart-fill' : 'bi-heart').me-1
                  span.like-count= likeCount
                  |  me gusta
              span
                i.bi.bi-chat.me-1
                | #{commentCount}

        //- SECCIÓN DE COMENTARIOS
        .card.shadow-sm.border-0.mb-4
          .card-body.p-4
            h6.fw-bold.mb-4
              i.bi.bi-chat-dots.me-2
              | Comentarios (#{commentCount})

            if user && post.commentsEnabled
              form.mb-4(action=`/posts/${post.id}/comments` method="POST")
                .mb-3
                  textarea.form-control(
                    name="content"
                    rows="2"
                    placeholder="Escribe un comentario..."
                    required
                    maxlength="500"
                  )
                .text-end
                  button.btn.btn-primary.btn-sm(type="submit")
                    i.bi.bi-send.me-1
                    | Publicar

            .comments-list
              if comments && comments.length > 0
                each comment in comments
                  .d-flex.mb-3.pb-3.border-bottom
                    .bg-light.rounded-circle.d-flex.align-items-center.justify-content-center.me-2(style="width: 32px; height: 32px; min-width: 32px;")
                      i.bi.bi-person.text-muted.small
                    .flex-grow-1
                      .d-flex.justify-content-between.align-items-start
                        div
                          span.fw-bold.small.me-2= comment.User ? comment.User.username : 'Anónimo'
                          small.text-muted.x-small= new Date(comment.created_at).toLocaleDateString('es-ES')
                        if user && comment.User && user.id === comment.User.id
                          form(action=`/posts/${post.id}/comments/${comment.id}/delete` method="POST")
                            button.btn.btn-sm.text-muted.p-0(type="submit")
                              i.bi.bi-x
                      p.mb-0.small.mt-1(style="white-space: pre-wrap;")= comment.content
              else
                .text-center.text-muted.py-4
                  p.small No hay comentarios aún.

  style.
    .x-small { font-size: 0.75rem; }
    /* Hacer que la imagen sea pegajosa en desktop */
    @media (min-width: 992px) {
      .col-lg-8 {
        position: sticky;
        top: 20px;
        align-self: flex-start;
      }
    }

  script(src="/js/likes.js")
