extends ../../layouts/app

block content
  .container.mt-4.mb-5

    .mb-3
      a.text-decoration-none.text-muted(href="/home")
        i.bi.bi-arrow-left.me-1
        | Volver al inicio

    .row.g-4.align-items-center
      .col-lg-8
        .post-media-container.bg-dark.rounded-3.overflow-hidden.shadow-sm(style="min-height: 400px; max-height: 80vh; display: flex; align-items: center; justify-content: center;")
          if post.images && post.images.length > 0
            if post.images.length === 1
              a.w-100.h-100.d-flex.align-items-center(href=`/posts/${post.id}` style="text-decoration: none;")
                img.w-100(
                  src=`/images/${post.images[0].id}`
                  alt=post.title
                  style="max-height: 80vh; object-fit: contain;"
                )
            else
              - const carouselId = 'post-carousel-' + post.id
              .carousel.slide.w-100(id=carouselId data-bs-ride="false")
                .carousel-inner
                  each img, idx in post.images
                    .carousel-item(class=idx === 0 ? 'active' : '')
                      a.w-100.h-100.d-flex.align-items-center(href=`/posts/${post.id}` style="text-decoration: none;")
                        img.d-block.w-100(
                          src=`/images/${img.id}`
                          alt=`${post.title} - Imagen ${idx + 1}`
                          style="max-height: 80vh; object-fit: contain;"
                        )
                if post.images.length > 1
                  button.carousel-control-prev(type="button" data-bs-target='#' + carouselId data-bs-slide="prev")
                    span.carousel-control-prev-icon
                  button.carousel-control-next(type="button" data-bs-target='#' + carouselId data-bs-slide="next")
                    span.carousel-control-next-icon
          else
            .text-center.text-white.py-5
              i.bi.bi-image.d-block(style="font-size: 3rem;")
              span Sin imágenes

        //- Licencias de las imágenes
        if post.images && post.images.length > 0
          .mt-2.d-flex.flex-wrap.gap-2
            each img, idx in post.images
              if img.license === 'copyright'
                span.badge.bg-warning.text-dark(title=`Imagen ${idx+1}: Con copyright`)
                  i.bi.bi-c-circle.me-1
                  | Copyright
              else
                span.badge.bg-success(title=`Imagen ${idx+1}: Libre de derechos`)
                  i.bi.bi-unlock.me-1
                  | Libre de derechos

      .col-lg-4
        .card.shadow-sm.border-0.mb-4
          .card-body.p-4
            h1.h4.fw-bold.mb-3= post.title
            if post.status === 'reported' || post.status === 'under_review'
              .alert.alert-warning.small.py-2.mb-3
                i.bi.bi-exclamation-triangle-fill.me-2
                | Contenido bajo revisión.

            
            .d-flex.align-items-center.mb-4
              .bg-secondary.rounded-circle.d-flex.align-items-center.justify-content-center.me-2(style="width: 40px; height: 40px; min-width: 40px;")
                i.bi.bi-person.text-white
              .flex-grow-1
                if post.User
                  a.fw-bold.text-decoration-none.small(href=`/profile/${post.User.username}`)= post.User.username
                else
                  span.fw-bold.small Anónimo
                .text-muted.x-small
                  span= new Date(post.created_at).toLocaleDateString('es-ES', { day: 'numeric', month: 'long' })

              if user && post.User && user.id === post.User.id
                .dropdown
                  button.btn.btn-sm.btn-link.text-muted(data-bs-toggle="dropdown")
                    i.bi.bi-three-dots
                  ul.dropdown-menu.dropdown-menu-end
                    li: a.dropdown-item(href=`/posts/${post.id}/edit`) Editar
                    li: hr.dropdown-divider
                    li
                      form(action=`/posts/${post.id}/delete` method="POST")
                        button.dropdown-item.text-danger(type="submit" onclick="return confirm('¿Eliminar?')") Eliminar
              else if user
                .dropdown
                  button.btn.btn-sm.btn-link.text-muted(data-bs-toggle="dropdown")
                    i.bi.bi-three-dots
                  ul.dropdown-menu.dropdown-menu-end
                    li
                      button.dropdown-item.text-danger.btn-report(data-target-type="post" data-target-id=post.id)
                        i.bi.bi-flag.me-2
                        | Denunciar

            if post.description
              .mb-4
                p.mb-0(style="white-space: pre-wrap; line-height: 1.6; font-size: 0.95rem;")= post.description

            if post.Tags && post.Tags.length > 0
              .mb-4
                .d-flex.flex-wrap.gap-2
                  each tag in post.Tags
                    a.badge.rounded-pill.bg-primary.bg-opacity-10.text-primary.px-3.py-2.small.text-decoration-none(href=`/search?tags=${tag.name}`)
                      i.bi.bi-tag.me-1
                      = tag.name

            //- ============================================
            //- SECCIÓN DE VALORACIÓN (ESTRELLAS)
            //- ============================================
            .border.rounded-3.p-3.mb-3(style="background: #f8f9fa;")
              .d-flex.justify-content-between.align-items-center.mb-2
                span.fw-semibold.small
                  i.bi.bi-star-fill.text-warning.me-1
                  | Valoración
                if ratingCount > 0
                  span.text-muted.small #{ratingCount} #{ratingCount === 1 ? 'valoración' : 'valoraciones'}
                else
                  span.text-muted.small Sin valoraciones aún

              //- Promedio visual
              if ratingAvg
                .d-flex.align-items-center.gap-2.mb-2
                  .rating-display
                    - for (let s = 1; s <= 5; s++)
                      i.bi.fs-5(class=s <= Math.round(parseFloat(ratingAvg)) ? 'bi-star-fill text-warning' : 'bi-star text-muted')
                  span.fw-bold.text-warning.fs-5= ratingAvg
                  span.text-muted.small / 5
              else
                p.text-muted.small.mb-2 Sé el primero en valorar esta publicación.

              //- Widget para valorar
              if user && !isAuthor
                if userRating
                  .alert.alert-success.py-2.px-3.mb-0.small
                    i.bi.bi-check-circle.me-1
                    | Valoraste con 
                    strong #{userRating} 
                    | #{userRating === 1 ? 'estrella' : 'estrellas'}
                else
                  .d-flex.align-items-center.gap-2
                    span.small.text-muted Tu valoración:
                    .star-rating-input(data-post-id=post.id)
                      - for (let s = 1; s <= 5; s++)
                        button.star-btn.btn.btn-link.p-0.text-muted(
                          type="button"
                          data-value=s
                          aria-label=`${s} ${s === 1 ? 'estrella' : 'estrellas'}`
                          title=`${s} ${s === 1 ? 'estrella' : 'estrellas'}`
                        )
                          i.bi.bi-star.fs-5
              else if !user
                small.text-muted
                  a.text-decoration-none(href="/auth/login") Iniciá sesión
                  |  para valorar esta publicación.
              else if isAuthor
                small.text-muted.fst-italic No podés valorar tu propia publicación.

            //- ============================================
            //- BOTÓN ME INTERESA
            //- ============================================
            if user && !isAuthor
              .mb-3
                button.btn.btn-outline-success.w-100.interest-btn(
                  id=`interest-btn-${post.id}`
                  data-post-id=post.id
                  type="button"
                )
                  i.bi.bi-hand-thumbsup.me-2
                  span.interest-text Me interesa adquirir
                a.btn.btn-sm.btn-link.text-muted.d-none#msg-link-btn(href=`/messages`)
                  i.bi.bi-chat-dots.me-1
                  | Ver conversación con el autor
            else if !user
              .mb-3
                a.btn.btn-outline-secondary.w-100(href="/auth/login")
                  i.bi.bi-lock.me-2
                  | Iniciá sesión para expresar interés

            .d-flex.align-items-center.gap-4.text-muted.border-top.pt-3
              span
                button.btn.btn-link.p-0.text-decoration-none.like-btn(
                  class=isLiked ? 'text-danger' : 'text-muted'
                  data-post-id=post.id
                  aria-label=isLiked ? 'Quitar me gusta' : 'Dar me gusta'
                )
                  i.bi(class=isLiked ? 'bi-heart-fill' : 'bi-heart').me-1
                  span.like-count= likeCount
                  |  me gusta
              span
                i.bi.bi-chat.me-1
                | #{commentCount}
              span.ms-auto
                button.btn.btn-link.p-0.text-decoration-none.save-btn(
                  class=isSaved ? 'text-primary' : 'text-muted'
                  data-post-id=post.id
                  aria-label=isSaved ? 'Quitar de guardados' : 'Guardar'
                )
                  i.bi(class=isSaved ? 'bi-bookmark-fill' : 'bi-bookmark')

        .card.shadow-sm.border-0.mb-4
          .card-body.p-4
            h6.fw-bold.mb-4
              i.bi.bi-chat-dots.me-2
              | Comentarios (#{commentCount})

            if user && post.commentsEnabled
              form.mb-4(action=`/posts/${post.id}/comments` method="POST")
                .mb-3
                  textarea.form-control(
                    name="content"
                    rows="2"
                    placeholder="Escribe un comentario..."
                    required
                    maxlength="500"
                  )
                .text-end
                  button.btn.btn-primary.btn-sm(type="submit")
                    i.bi.bi-send.me-1
                    | Publicar

            .comments-list
              if comments && comments.length > 0
                each comment in comments
                  .d-flex.mb-3.pb-3.border-bottom
                    .bg-light.rounded-circle.d-flex.align-items-center.justify-content-center.me-2(style="width: 32px; height: 32px; min-width: 32px;")
                      i.bi.bi-person.text-muted.small
                    .flex-grow-1
                      .d-flex.justify-content-between.align-items-start
                        div
                          span.fw-bold.small.me-2= comment.User ? comment.User.username : 'Anónimo'
                          small.text-muted.x-small= new Date(comment.created_at).toLocaleDateString('es-ES')
                        if user && comment.User && user.id === comment.User.id
                          form(action=`/posts/${post.id}/comments/${comment.id}/delete` method="POST")
                            button.btn.btn-sm.text-muted.p-0(type="submit")
                              i.bi.bi-x
                        else if user && post.User && user.id === post.User.id
                          form(action=`/posts/${post.id}/comments/${comment.id}/delete` method="POST")
                            button.btn.btn-sm.text-danger.p-0.me-2(type="submit" title="Eliminar del post")
                              i.bi.bi-trash
                        else if user
                          button.btn.btn-sm.text-muted.p-0.btn-report(data-target-type="comment" data-target-id=comment.id title="Denunciar")
                            i.bi.bi-flag
                      p.mb-0.small.mt-1(style="white-space: pre-wrap;")= comment.content
              else
                .text-center.text-muted.py-4
                  p.small No hay comentarios aún.

  style.
    .x-small { font-size: 0.75rem; }
    @media (min-width: 992px) {
      .col-lg-8 {
        position: sticky;
        top: 20px;
        align-self: flex-start;
      }
    }
    .star-btn i { transition: color 0.15s; }
    .star-btn:hover i, .star-btn.hovered i { color: #f5c518 !important; }
    .star-btn.selected i { color: #f5c518 !important; }

  .modal.fade#reportModal(tabindex="-1" aria-labelledby="reportModalLabel" aria-hidden="true")
    .modal-dialog
      .modal-content
        .modal-header.bg-danger.text-white
          h5.modal-title#reportModalLabel Denunciar Contenido
          button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
        form#reportForm
          .modal-body
            input(type="hidden" id="reportTargetType" name="targetType")
            input(type="hidden" id="reportTargetId" name="targetId")
            .mb-3
              label.form-label(for="reportReason") Motivo de la denuncia
              select.form-select#reportReason(name="reason" required)
                option(value="" disabled selected) Selecciona un motivo...
                option(value="SPAM") Spam
                option(value="CONTENIDO_INAPROPIADO") Contenido Inapropiado
                option(value="DESNUDEZ") Desnudez
                option(value="VIOLENCIA") Violencia
                option(value="DISCURSO_DE_ODIO") Discurso de Odio
                option(value="COPYRIGHT") Infracción de Copyright
                option(value="ACOSO") Acoso
                option(value="ESTAFA") Estafa o Fraude
                option(value="INFORMACION_FALSA") Información Falsa
                option(value="OTRO") Otro
            .mb-3
              label.form-label(for="reportDescription") Descripción (opcional)
              textarea.form-control#reportDescription(name="description" rows="3" placeholder="Aporta más detalles...")
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
            button.btn.btn-danger(type="submit") Enviar Denuncia

  script(src="/js/likes.js")
  script(src="/js/bookmarks.js")
  script(src="/js/reports.js")
  script(src="/js/ratings.js")
  script(src="/js/interest.js")
