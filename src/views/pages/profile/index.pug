extends ../../layouts/app

block content
  .container.mt-4
    .card.shadow-sm
      .card-body.p-4
        .row.align-items-center
          .col-md-2.text-center
            // Placeholder de avatar con Bootstrap Icons
            .bg-secondary.rounded-circle.d-flex.align-items-center.justify-content-center.mx-auto.mb-3(style="width: 110px; height: 110px;")
              i.bi.bi-person.text-white(style="font-size: 3rem;")
          .col-md-7
            h2.card-title.mb-1= profileUser.username
            p.text-muted.mb-2
              small
                i.bi.bi-calendar3.me-1
                | Miembro desde 
                span= profileUser.created_at ? profileUser.created_at.toLocaleDateString('es-AR') : 'N/A'
          .col-md-3.text-end
            if isOwner
              a.btn.btn-primary(href="/profile/edit") Editar Perfil
            else if isFollowing
              form(method="POST" action=`/profile/${profileUser.username}/follow`)
                button.btn.btn-outline-danger(type="submit") Dejar de seguir
            else
              form(method="POST" action=`/profile/${profileUser.username}/follow`)
                button.btn.btn-primary(type="submit") Seguir

        // Estadísticas
        .row.mt-4.text-center
          .col-4
            a.fw-bold.text-decoration-none.d-inline-flex.align-items-center.gap-2(href=`/profile/${profileUser.username}/followers`)
              span.badge.bg-primary= followerCount
              span.text-muted Seguidores
          .col-4
            a.fw-bold.text-decoration-none.d-inline-flex.align-items-center.gap-2(href=`/profile/${profileUser.username}/following`)
              span.badge.bg-success= followingCount
              span.text-muted Siguiendo
          .col-4
            .d-inline-flex.align-items-center.gap-2
              span.badge.bg-light.text-dark= posts.length
              span.text-muted Publicaciones

        hr.my-4
        h5.h6.text-uppercase.text-muted.mb-3 Publicaciones
        .row.g-3
          each post in posts
            .col-md-4.col-sm-6.mb-4
              .card.h-100.shadow-sm
                // ✅ Galería de imágenes (Slide si hay más de una)
                if post.images && post.images.length > 0
                  if post.images.length === 1
                    a(href=`/posts/${post.id}`)
                      img.card-img-top(src=post.images[0].url alt="Post" style="height: 200px; object-fit: cover;")
                  else
                    - const carouselId = 'carousel-profile-' + post.id
                    .carousel.slide(id=carouselId data-bs-ride="carousel")
                      .carousel-inner
                        each img, index in post.images
                          .carousel-item(class=index === 0 ? 'active' : '')
                            a(href=`/posts/${post.id}`)
                              img.d-block.w-100(
                                src=img.url
                                alt="Post"
                                style="height: 200px; object-fit: cover;"
                                loading="lazy"
                              )
                      button.carousel-control-prev(type="button" data-bs-target='#' + carouselId data-bs-slide="prev")
                        span.carousel-control-prev-icon(aria-hidden="true")
                      button.carousel-control-next(type="button" data-bs-target='#' + carouselId data-bs-slide="next")
                        span.carousel-control-next-icon(aria-hidden="true")
                else
                  a(href=`/posts/${post.id}`)
                    img.card-img-top(
                      src="/placeholder.svg" 
                      alt="Sin imagen" 
                      style="height: 200px; object-fit: cover;"
                    )

                .card-body
                  h6.card-title= post.title
                  p.card-text.text-truncate.small.mb-1= post.description || 'Sin descripción'
                  
                  //- Tags
                  if post.Tags && post.Tags.length > 0
                    .d-flex.flex-wrap.gap-1.mb-2
                      each tag in post.Tags
                        span.badge.rounded-pill.bg-light.text-primary.border.x-small(style="font-size: 0.7rem;")= tag.name
                  small.text-muted.d-block.mb-2= new Date(post.created_at).toLocaleDateString('es-AR')
                  
                  //- Likes & Bookmarks
                  .d-flex.align-items-center.gap-3.mb-2
                    - const isLiked = user && post.Likes && post.Likes.some(l => l.UserId === user.id)
                    - const likeCount = post.Likes ? post.Likes.length : 0
                    button.btn.btn-link.p-0.text-decoration-none.like-btn.small(
                      class=isLiked ? 'text-danger' : 'text-muted'
                      data-post-id=post.id
                      aria-label=isLiked ? 'Quitar me gusta' : 'Dar me gusta'
                    )
                      i.bi(class=isLiked ? 'bi-heart-fill' : 'bi-heart').me-1
                      span.like-count= likeCount
                      |  me gusta

                    - const isSaved = user && post.Bookmarks && post.Bookmarks.some(b => b.UserId === user.id)
                    button.btn.btn-link.p-0.text-decoration-none.save-btn.small(
                      class=isSaved ? 'text-primary' : 'text-muted'
                      data-post-id=post.id
                      aria-label=isSaved ? 'Quitar de guardados' : 'Guardar'
                    )
                      i.bi(class=isSaved ? 'bi-bookmark-fill' : 'bi-bookmark')

                  .d-flex.justify-content-between.mt-3
                    // 🔐 VALIDACIÓN: Solo el dueño ve Editar/Eliminar
                    if isOwner
                      a.btn.btn-sm.btn-outline-primary(href=`/profile/edit/${post.id}`) ✏️ Editar
                      
                      form(action=`/profile/delete/${post.id}`, method='POST', class='d-inline')
                        button.btn.btn-sm.btn-outline-danger(type='submit', onclick="return confirm('¿Eliminar esta publicación y sus imágenes?')")
                          | 🗑️ Eliminar
                    else
                      // 👁️ Visitantes: Solo pueden ver la publicación
                      a.btn.btn-sm.btn-outline-secondary(href=`/posts/${post.id}`) Ver publicación

          // ✅ Mensaje cuando no hay posts
          if posts.length === 0
            .col-12.text-center.text-muted.py-4
              if isOwner
                | Aún no has creado publicaciones.
                a.btn.btn-link.p-0.ms-1(href='/posts/create') Crear una ahora
              else
                | Este usuario aún no tiene publicaciones.

  script(src="/js/likes.js")
  script(src="/js/bookmarks.js")