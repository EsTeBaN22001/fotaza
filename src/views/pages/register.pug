extends ../layouts/auth

block content
  .container
    .row.justify-content-center.mt-5
      .col-md-6.col-lg-4

        .card.shadow
          .card-body

            h3.text-center.mb-4 Registro

            form(method="POST" action="/auth/register")
              input(type="hidden" name="returnTo" value=returnTo)

              .mb-3
                label.form-label Usuario
                input.form-control(
                  type="text"
                  name="username"
                  placeholder="Usuario"
                  value=old.username
                )

              .mb-3
                label.form-label Email
                input.form-control(
                  type="email"
                  name="email"
                  placeholder="Email"
                  value=old.email
                )

              .mb-3
                label.form-label Password
                input.form-control(
                  type="password"
                  name="password"
                  placeholder="Password"
                )

              button.btn.btn-primary.w-100(type="submit") Registrarse