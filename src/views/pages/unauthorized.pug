extends ../layouts/app

block content
  .container.py-5
    .row.justify-content-center.text-center
      .col-md-6.py-5
        .card.border-0.shadow-lg.p-4.glass-morphism
          .mb-4
            .display-1.text-primary.mb-3
              i.bi.bi-shield-lock-fill
            h1.fw-bold.h2 Contenido Exclusivo
            p.text-muted.lead
              | ¡Vaya! Parece que has intentado acceder a una zona que requiere estar registrado.
          
          .alert.alert-info.mb-4.text-start
            h6.fw-bold 
              i.bi.bi-info-circle-fill.me-2
              | ¿Por qué registrarte?
            ul.mb-0.small
              li Interactúa con la comunidad (likes y comentarios)
              li Sigue a tus fotógrafos favoritos
              li Comparte tus propias obras maestras
              li Gestiona tu perfil personal
          
          .d-grid.gap-2.mt-4
            a.btn.btn-primary.btn-lg(href=`/auth/register?returnTo=${returnTo}`)
              i.bi.bi-person-plus-fill.me-2
              | Crear mi cuenta gratis
            a.btn.btn-outline-primary(href=`/auth/login?returnTo=${returnTo}`)
              | Iniciar sesión
          
          .mt-4
            a.text-muted.text-decoration-none(href='/home')
              i.bi.bi-arrow-left.me-1
              | Volver al Inicio

    style.
      .glass-morphism {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-radius: 20px;
      }
      .display-1 i {
        filter: drop-shadow(0 0 10px rgba(13, 110, 253, 0.3));
      }
