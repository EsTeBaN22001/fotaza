extends ../layouts/app

block content
  .row.justify-content-center
    .col-md-6

      .card.shadow
        .card-body

          h4.mb-3 Crear Post

          form(method="POST" action="/posts" enctype="multipart/form-data")

            .mb-3
              label.form-label Título
              input.form-control(
                type="text"
                name="title"
                value=old.title
              )

            .mb-3
              label.form-label Descripción
              textarea.form-control(name="description")= old.description

            .mb-3
              label.form-label Imágenes
              input.form-control(
                type="file"
                name="images"
                multiple
                accept="image/*"
              )

            if tags && tags.length > 0
              .mb-3
                label.form-label Etiquetas (Tags)
                .d-flex.flex-wrap.gap-2
                  each tag in tags
                    .form-check
                      input.form-check-input(
                        type="checkbox"
                        name="tags"
                        value=tag.id
                        id=`tag-${tag.id}`
                        checked=(old.tags && (Array.isArray(old.tags) ? old.tags.includes(tag.id.toString()) : old.tags === tag.id.toString()))
                      )
                      label.form-check-label(for=`tag-${tag.id}`)= tag.name

            .mb-4
              .form-check.form-switch
                input.form-check-input(
                  type="checkbox"
                  name="commentsEnabled"
                  id="commentsEnabled"
                  checked=(old.commentsEnabled !== undefined ? old.commentsEnabled === 'on' : true)
                )
                label.form-check-label(for="commentsEnabled") Habilitar comentarios en esta publicación

            button.btn.btn-primary.w-100(type="submit") Publicar