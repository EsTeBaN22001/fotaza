# ==========================================
# SERVIDOR & ENTORNO
# ==========================================
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ==========================================
# BASE DE DATOS (MySQL)
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fotaza
DB_USER=root
DB_PASS=
DB_TIMEZONE=-03:00
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_SSL=false

# ==========================================
# SEGURIDAD & AUTENTICACIÓN
# ==========================================
JWT_SECRET=reemplazar_con_una_firma_secreta_larga_y_segura
JWT_EXPIRES_IN=7d

# ==========================================
# ARCHIVOS & MULTER
# ==========================================
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ==========================================
# REGLAS DE NEGOCIO (Ajustables según consigna)
# ==========================================
REPORT_THRESHOLD=3
DEACTIVATION_THRESHOLD=3
DEFAULT_WATERMARK=FOTAZA ©
